$ips = Get-Content ".\ips.txt"
$port = 443

foreach ($ip in $ips) {
    $result = Test-NetConnection $ip -Port $port -WarningAction SilentlyContinue
    if ($result.TcpTestSucceeded) {
        Write-Host "$ip OK"
        Add-Content ".\good_ips.txt" $ip
    } else {
        Write-Host "$ip FAIL"
    }
}
